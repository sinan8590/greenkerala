import { NextRequest, NextResponse } from 'next/server';
import { MongoClient, ObjectId } from 'mongodb';

const MONGODB_URI = process.env.MONGODB_URI;
const MONGODB_DB_NAME = process.env.MONGODB_DB_NAME || 'green-kerala';

let client: MongoClient | null = null;
let galleryCollection: any = null;

async function getCollection() {
  if (!galleryCollection) {
    if (!client) {
      client = new MongoClient(MONGODB_URI!);
      await client.connect();
    }
    const db = client.db(MONGODB_DB_NAME);
    galleryCollection = db.collection('gallery');
  }
  return galleryCollection;
}

export async function GET() {
  try {
    const collection = await getCollection();
    const galleryItems = await collection.find().sort({ createdAt: -1 }).toArray();
    const items = galleryItems.map((item: any) => ({
      id: item._id.toString(),
      url: item.url,
      storagePath: item.storagePath,
      ownerId: item.ownerId,
      createdAt: item.createdAt,
    }));
    return NextResponse.json(items);
  } catch (error) {
    console.error('Gallery fetch error:', error);
    return NextResponse.json({ error: 'Failed to fetch gallery items.' }, { status: 500 });
  }
}

export async function POST(request: NextRequest) {
  try {
    const { url, ownerId } = await request.json();
    if (!url) {
      return NextResponse.json({ error: 'Image URL is required.' }, { status: 400 });
    }

    const collection = await getCollection();
    const result = await collection.insertOne({
      url,
      ownerId: ownerId || null,
      storagePath: null,
      createdAt: new Date(),
      updatedAt: new Date(),
    });

    return NextResponse.json({ id: result.insertedId.toString(), url }, { status: 201 });
  } catch (error) {
    console.error('Gallery create error:', error);
    return NextResponse.json({ error: 'Failed to save gallery image.' }, { status: 500 });
  }
}

export async function DELETE(request: NextRequest) {
  const url = new URL(request.url);
  const id = url.pathname.split('/').pop();
  if (!id) {
    return NextResponse.json({ error: 'ID required' }, { status: 400 });
  }

  try {
    const collection = await getCollection();
    const result = await collection.deleteOne({ _id: new ObjectId(id) });
    if (result.deletedCount === 0) {
      return NextResponse.json({ error: 'Gallery item not found.' }, { status: 404 });
    }
    return NextResponse.json({ success: true });
  } catch (error) {
    console.error('Gallery delete error:', error);
    return NextResponse.json({ error: 'Failed to delete gallery item.' }, { status: 500 });
  }
}